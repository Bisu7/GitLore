generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  githubId    String?  @unique
  email       String   @unique
  name        String?
  avatarUrl   String?
  accessToken String? // should be encrypted in practice
  createdAt   DateTime @default(now())
  repos       Repo[]
}

model Repo {
  id                String            @id @default(cuid())
  userId            String
  githubRepoId      String            @unique
  fullName          String
  defaultBranch     String?
  ingestionStatus   String            @default("pending")
  ingestionProgress Float             @default(0)
  createdAt         DateTime          @default(now())
  
  user              User              @relation(fields: [userId], references: [id])
  commits           Commit[]
  prs               PR[]
  embeddingChunks   EmbeddingChunk[]
}

model Commit {
  id          String       @id @default(cuid())
  repoId      String
  sha         String
  message     String
  authorEmail String?
  authorName  String?
  timestamp   DateTime
  parentShas  String[]
  
  repo        Repo         @relation(fields: [repoId], references: [id])
  files       CommitFile[]
  ticketRefs  TicketRef[]
  prs         PR[]
  chunks      EmbeddingChunk[]
}

model CommitFile {
  id        String @id @default(cuid())
  commitId  String
  filePath  String
  additions Int    @default(0)
  deletions Int    @default(0)
  patch     String?
  
  commit    Commit @relation(fields: [commitId], references: [id])
}

model TicketRef {
  id         String @id @default(cuid())
  commitId   String
  source     String // e.g. JIRA, LINEAR, GITHUB
  externalId String
  rawRef     String
  
  commit     Commit @relation(fields: [commitId], references: [id])
}

model PR {
  id             String      @id @default(cuid())
  repoId         String
  commitId       String?
  githubPrNumber Int
  title          String
  body           String?
  state          String
  mergedAt       DateTime?
  
  repo           Repo        @relation(fields: [repoId], references: [id])
  commit         Commit?     @relation(fields: [commitId], references: [id])
  comments       PRComment[]
}

model PRComment {
  id              String   @id @default(cuid())
  prId            String
  githubCommentId String   @unique
  authorLogin     String
  body            String
  createdAt       DateTime
  
  pr              PR       @relation(fields: [prId], references: [id])
}

model EmbeddingChunk {
  id        String   @id @default(cuid())
  repoId    String
  commitId  String?
  content   String
  metadata  Json
  createdAt DateTime @default(now())
  
  embedding Unsupported("vector(384)")?
  
  repo      Repo     @relation(fields: [repoId], references: [id])
  commit    Commit?  @relation(fields: [commitId], references: [id])
}
